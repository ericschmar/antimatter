{
	"name": "antimatter",
	"version": "0.2.7",
	"type": "module",
	"description": "A minimal Mattermost desktop client built with ElectroBun, React, and Radix UI",
	"scripts": {
		"start": "electrobun dev",
		"dev": "electrobun dev --watch",
		"build": "electrobun build",
		"build:release": "electrobun build --env=stable",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"version:bump": "bun scripts/bump-version.ts",
		"version:check": "bun scripts/check-version.ts",
		"build:canary": "electrobun build --env=canary"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@emoji-mart/data": "^1.2.1",
		"@emoji-mart/react": "^1.1.1",
		"@iamjariwala/react-doc-viewer": "^1.8.0",
		"@mdxeditor/editor": "^4.0.0",
		"@radix-ui/colors": "^3.0.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tanstack/react-virtual": "^3.14.2",
		"electrobun": "1.18.1",
		"electrobun-multi-window": ".",
		"emoji-mart": "^5.6.0",
		"font-list": "^2.0.2",
		"lucide-react": "^1.16.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-markdown": "^10.1.0",
		"react-resizable": "^4.0.1",
		"remark-gfm": "^4.0.1",
		"swr": "^2.4.1",
		"valtio": "^2.3.2"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.184.1",
		"typescript": "^5.7.2"
	}
}
